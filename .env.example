# Copy to .env and fill in. Get a key at https://nano-gpt.com (Settings → API).
NANOGPT_API_KEY=sk-nano-...

# --- optional ---
# NANOGPT_MODEL=xiaomi/mimo-v2.5-pro-ultraspeed
# PORT=8787

# Swap back to OAuth once NanoGPT fixes their form-action CSP (see nanogpt-bug-report.md).
# With this set, NANOGPT_API_KEY is ignored and the PKCE loopback flow runs instead.
# NANOGPT_AUTH=oauth
